# Copy to .env.local and fill in values

NODE_ENV=

# API
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Admin live API (dev)
# - Base URL should point at the backend server (NOT the /api prefix).
# - Admin key is required to access /v1/admin/* in the Nest backend.
NEXT_PUBLIC_ADMIN_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_HERALD_ADMIN_KEY=

# Auth — NEXTAUTH_SECRET is used ONLY by NextAuth to sign its own session cookie.
# The backend issues and verifies JWTs independently. Frontend never touches signing.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Mock data — set "true" to enable MSW mocks in production builds
# In development mode, mocks are always enabled regardless of this setting
NEXT_PUBLIC_ENABLE_MOCKS=false
ENABLE_MOCKS=false
